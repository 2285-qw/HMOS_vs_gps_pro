/**
 * 解码器支持的MIME类型
 */
export enum MimeType {
  /**
   * H.264/AVC视频
   */
  H264 = "video/avc",

  /**
   * H.265/HEVC视频
   */
  H265 = "video/hevc",

  /**
   * MPEG-4视频
   */
  MPEG4 = "video/mp4v-es",

  /**
   * VP8视频
   */
  VP8 = "video/x-vnd.on2.vp8",

  /**
   * VP9视频
   */
  VP9 = "video/x-vnd.on2.vp9"
}
