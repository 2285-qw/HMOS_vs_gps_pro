{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "orientation": "landscape", // 固定横屏
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home",
              "ohos.usb.action.USB_ACCESSORY_ATTACHED"
            ],
            "uris": [
              {
                "scheme": "usb",
                "host": "*",
                "port": "*",
                "path": "/*"
              }
            ]
          }
        ],
        "metadata": [
          {
            "name": "ohos.ability.usb",
            "resource": "$profile:usb_config"
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:reason",
        // 需在资源文件中定义原因
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          // 关联的Ability（主Ability名称）
          "when": "always"
          // 权限使用时机（inuse表示使用时申请）
        }
      },
      // 获取网络信息权限
      {
        "name": "ohos.permission.GET_WIFI_INFO"
      },
     /* {
        "name": "ohos.permission.READ_WRITE_USB_DEV",
        "reason": "$string:UsbReason",
        // 需在资源文件中定义原因
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          // 关联的Ability（主Ability名称）
          "when": "always"
          // 权限使用时机（inuse表示使用时申请）
        }
      },*/
      {
        "name": "ohos.permission.KEEP_BACKGROUND_RUNNING", // 后台监听需加
        "reason": "$string:UsbOn",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "always"
        }
      },{
        "name": "ohos.permission.READ_MEDIA",
        "reason": "$string:log_w",
        "usedScene": {
          "when": "always"
        }
      }, {
        "name": "ohos.permission.WRITE_MEDIA",
        "reason":  "$string:log_r",
        "usedScene": {
          "when": "always"
        }
      },
     /* {
        "name": "ohos.permission.CAPTURE_SCREEN",
        "reason": "$string:record",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },*/
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:sound",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.LOCATION",
        "reason": "$string:location",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.APPROXIMATELY_LOCATION",
        "reason": "$string:a_location",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "inuse"
        }
      }
    ]
  }
}